                                                        <iconPacks:PackIconMaterial Kind="Plus" Width="12" Height="12" Margin="0,0,5,0" VerticalAlignment="Center" Foreground="White"/>
                                                        <TextBlock Text="Ekle" Foreground="White" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                    <Button Content="Kapat" Style="{StaticResource GhostButton}" Padding="15,8" Click="CloseSuspiciousSenders_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Scroll edilebilir liste -->
                        <ScrollViewer Style="{StaticResource DarkScrollViewer}" Padding="25,5,15,5">
                            <ItemsControl x:Name="SuspiciousSendersList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1F2226" CornerRadius="6" Padding="12,10" Margin="0,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <iconPacks:PackIconMaterial Grid.Column="0" Kind="AccountAlertOutline" Width="18" Height="18" Foreground="#EF4444" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Email}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding DateAdded, StringFormat='Eklenme: {0}'}" Foreground="#666" FontSize="10" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <Button Grid.Column="2" Cursor="Hand" Background="Transparent" BorderThickness="0" Padding="6" Tag="{Binding Email}" Click="RemoveSuspiciousSender_Click" ToolTip="Listeden çıkar">
