<Window x:Class="CyberSecurityAssistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="SiberBelediye Kalkanı"
        Height="580" Width="1040" 
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="ShieldGlow" Storyboard.TargetProperty="Opacity" From="0.3" To="1.0" Duration="0:0:0.5" />
            <DoubleAnimation Storyboard.TargetName="ShieldGlow" Storyboard.TargetProperty="BlurRadius" From="20" To="60" Duration="0:0:0.5" />
        </Storyboard>

        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="15,8" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlowScanButton" TargetType="Button">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="GlowBorder" CornerRadius="8">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#4ADE80" Offset="0.0"/>
                                    <GradientStop Color="#22C55E" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" Color="#22C55E" Opacity="0.6" ShadowDepth="0"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="GlowBorder" Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)" To="25" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="GlowBorder" Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)" To="0.9" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="GlowBorder" Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)" To="15" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="GlowBorder" Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)" To="0.6" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusCard" TargetType="Border">
            <Setter Property="Background" Value="#661E1E1E"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ModernProgressBar" TargetType="ProgressBar">
            <Setter Property="Foreground" Value="#22C55E"/>
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <Grid x:Name="PART_Track">
                                <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" HorizontalAlignment="Left" CornerRadius="3"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="GhostBorder" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="GhostBorder" Property="Background" Value="#1AFFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="20" CornerRadius="15" BorderThickness="1.5">
        <Border.Background>
            <SolidColorBrush Color="#121212" Opacity="0.85"/>
        </Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#40FFFFFF" Offset="0.0"/>
                <GradientStop Color="#05FFFFFF" Offset="1.0"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.7" Color="Black" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="90"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,15,0">
                <Button Content="TR" Click="LangTR_Click" Background="Transparent" Foreground="#A0A0A0" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Margin="0,0,5,0"/>
                <TextBlock Text="|" Foreground="#555" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <Button Content="EN" Click="LangEN_Click" Background="Transparent" Foreground="#A0A0A0" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Margin="0,0,5,0"/>

                <Button Margin="0,0,5,0" Foreground="#A0A0A0" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="OpenSettings_Click">
                    <iconPacks:PackIconMaterial Kind="Cog" Width="16" Height="16"/>
                </Button>

                <Button Content="—" Foreground="Gray" Background="Transparent" BorderThickness="0" Width="30" Cursor="Hand" Click="Minimize_Click"/>

                <Button x:Name="MaximizeBtn" Foreground="Gray" Background="Transparent" BorderThickness="0" Width="30" Cursor="Hand" Click="Maximize_Click">
                    <iconPacks:PackIconMaterial x:Name="MaximizeIcon" Kind="WindowMaximize" Width="12" Height="12"/>
                </Button>

                <Button Content="✕" Foreground="Gray" Background="Transparent" BorderThickness="0" Width="30" Cursor="Hand" Click="Close_Click"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="20,10,20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6*"/>
                    <ColumnDefinition Width="4*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#661E1E1E" CornerRadius="10" Padding="20" BorderBrush="#33FFFFFF" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                            <Button x:Name="TabMetin" Style="{StaticResource TabButton}" Foreground="White" Background="#333" Click="TabMetin_Click">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="FileDocumentOutline" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource TabText}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="TabUrl" Style="{StaticResource TabButton}" Click="TabUrl_Click">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="LinkVariant" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource TabUrl}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="TabDosya" Style="{StaticResource TabButton}" Click="TabDosya_Click">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Paperclip" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource TabFile}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,0,0,15">

                            <Border x:Name="PanelText" Background="#40000000" CornerRadius="8" BorderBrush="#333" BorderThickness="1" Visibility="Visible">
                                <Grid>
                                    <TextBlock x:Name="TextExampleHint" 
                                               Text="{DynamicResource TextExampleHint}" 
                                               Foreground="#666666" 
                                               FontSize="14" 
                                               Padding="15" 
                                               TextWrapping="Wrap" 
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=InputText}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBox x:Name="InputText" 
                                             CaretBrush="White" 
                                             Background="Transparent" 
                                             Foreground="#D0D0D0" 
                                             BorderThickness="0" 
                                             TextWrapping="Wrap" 
                                             AcceptsReturn="True" 
                                             Padding="15" 
                                             FontSize="14"/>
                                </Grid>
                            </Border>

                            <Border x:Name="PanelUrl" Background="#40000000" CornerRadius="8" BorderBrush="#333" BorderThickness="1" Visibility="Collapsed" Padding="20">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="Earth" Width="45" Height="45" Foreground="#A0A0A0" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="TextUrlHint" Text="{DynamicResource TextUrlHint}" Foreground="#A0A0A0" FontSize="14" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                                    <Border Background="#151718" CornerRadius="8" BorderThickness="1" BorderBrush="#555" Width="380" Height="42">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <iconPacks:PackIconMaterial Grid.Column="0" Kind="Link" Foreground="#888" VerticalAlignment="Center" Margin="12,0,5,0"/>

                                            <Grid Grid.Column="1">
                                                <TextBlock x:Name="LinkText" Text="{DynamicResource LinkText}" Foreground="#666666" FontSize="14" VerticalAlignment="Center" Padding="5,0,15,0" IsHitTestVisible="False">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Text, ElementName=InputUrl}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <TextBox x:Name="InputUrl" CaretBrush="White" Background="Transparent" Foreground="White" BorderThickness="0" Padding="5,0,15,0" FontSize="14" VerticalContentAlignment="Center" Text=""/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border x:Name="PanelDosya" Background="#40000000" CornerRadius="8" BorderBrush="#333" BorderThickness="1" Visibility="Collapsed" Padding="20" AllowDrop="True" Drop="PanelDosya_Drop">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="FolderUploadOutline" Width="45" Height="45" Foreground="#A0A0A0" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="SelectedFileNameText" Text="{DynamicResource SelectedFileNameText}" Foreground="#A0A0A0" FontSize="14" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                                    <Button x:Name="FolderUploadButton" Content="{DynamicResource FolderUploadButton}" Width="160" Height="35" Foreground="White" Cursor="Hand" Click="BrowseFile_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#333" CornerRadius="5" BorderBrush="#555" BorderThickness="1">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <CheckBox x:Name="AutoScanCheckBox" 
                                              Content="{DynamicResource RealTimeReader}" 
                                              Foreground="#A0A0A0" 
                                              HorizontalAlignment="Center" 
                                              Margin="0,20,0,0" 
                                              Cursor="Hand" 
                                              Click="AutoScan_Click"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Button Grid.Row="2" Style="{StaticResource GlowScanButton}" Click="Scan_button_Click">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Radar" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource StartScanText}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="ThreatRadar" Text="{DynamicResource ThreatRadar}" Foreground="#A0A0A0" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <Grid Width="120" Height="120" Margin="0,0,0,20">
                        <iconPacks:PackIconMaterial x:Name="ShieldIcon" Kind="ShieldCheckOutline" Width="80" Height="80" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#22C55E">
                            <iconPacks:PackIconMaterial.Effect>
                                <DropShadowEffect x:Name="ShieldGlow" BlurRadius="40" Color="#22C55E" Opacity="0.8" ShadowDepth="0"/>
                            </iconPacks:PackIconMaterial.Effect>
                        </iconPacks:PackIconMaterial>
                    </Grid>

                    <TextBlock x:Name="StatusText" Text="{DynamicResource StatusText}" Foreground="#4ADE80" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="360" Margin="0,0,0,10"/>

                    <ScrollViewer MaxHeight="80" VerticalScrollBarVisibility="Auto" Margin="0,15,0,15">
                        <TextBlock x:Name="ScanDescriptionText" 
                                   Text="{DynamicResource ScanDescriptionText}" 
                                   TextWrapping="Wrap" 
                                   TextAlignment="Center" 
                                   Foreground="#A0A0A0" 
                                   FontSize="13" />
                    </ScrollViewer>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="PdfReportButton" Width="125" BorderThickness="1" BorderBrush="#3B82F6" Background="#403B82F6" Foreground="White" Padding="8" Margin="0,0,10,0" Cursor="Hand" Visibility="Collapsed" Click="PdfReport_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="5" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <iconPacks:PackIconMaterial Kind="FilePdfBox" Margin="0,0,5,0" VerticalAlignment="Center" Foreground="#FF93C5FD"/>
                                            <TextBlock Text="{DynamicResource DownloadPDF}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12"/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="DeleteThreatButton" Width="125" BorderThickness="1" BorderBrush="#EF4444" Background="#40EF4444" Foreground="White" Padding="8" Margin="0,0,10,0" Cursor="Hand" Visibility="Collapsed" Click="DeleteThreat_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="5" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <iconPacks:PackIconMaterial Kind="DeleteForever" Margin="0,0,5,0" VerticalAlignment="Center" Foreground="#FCA5A5"/>
                                            <TextBlock Text="{DynamicResource DeleteThreat}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12"/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="ResetButton" Width="125" BorderThickness="1" BorderBrush="#555555" Background="#333333" Foreground="White" Padding="8" Cursor="Hand" Visibility="Hidden" Click="Reset_button_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="5" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <iconPacks:PackIconMaterial Kind="Refresh" Margin="0,0,5,0" VerticalAlignment="Center" Foreground="#A0A0A0"/>
                                            <TextBlock Text="{DynamicResource NewScan}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12"/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <ProgressBar x:Name="ScanProgressBar" Grid.Row="2" Style="{StaticResource ModernProgressBar}" Height="6" Margin="20,0,20,10" Maximum="100" Visibility="Collapsed"/>

            <Grid Grid.Row="3" Margin="20,0,20,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource StatusCard}" Margin="0,0,10,0">
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <iconPacks:PackIconMaterial x:Name="AiStatusIcon" Kind="RobotOutline" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource AiEngineTitle}" Foreground="White" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="AiStatusText" Text="Aktif - Doğruluk Oranı: %98.1" Foreground="#A0A0A0" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource StatusCard}" Margin="10,0,0,0">
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <iconPacks:PackIconMaterial x:Name="ApiStatusIcon" Kind="CloudSearchOutline" Foreground="#22C55E" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource VtShieldTitle}" Foreground="White" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="ApiStatusText" Text="API Bağlantısı: Devrede" Foreground="#A0A0A0" FontSize="12"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid x:Name="SettingsOverlay" Visibility="Collapsed" Background="#D9000000" Grid.RowSpan="4" Panel.ZIndex="100">
                <Border Background="#1A1C1E" CornerRadius="12" BorderBrush="#444" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="30" Width="450">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                            <iconPacks:PackIconMaterial Kind="Cog" Foreground="White" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Uygulama Ayarları" Foreground="White" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="VirusTotal API Anahtarı:" Foreground="#A0A0A0" FontSize="14" Margin="0,0,0,8"/>
                        <Border Background="#121212" CornerRadius="5" BorderThickness="1" BorderBrush="#555" Margin="0,0,0,15">
                            <StackPanel Margin="10,10,10,10">
                                <TextBlock Text="VirusTotal API Anahtarı:" Foreground="#A0A0A0" Margin="0,0,0,5" FontSize="13"/>
                                <Grid Margin="0,0,0,10">
                                    <PasswordBox x:Name="ApiPasswordBox" 
                                                 PasswordChar="•" 
                                                 Background="#222222" 
                                                 Foreground="White" 
                                                 BorderBrush="#555" 
                                                 BorderThickness="1" 
                                                 Padding="10,8,35,8" 
                                                 HorizontalAlignment="Stretch"
                                                 PasswordChanged="ApiPasswordBox_PasswordChanged"/>

                                    <TextBox x:Name="ApiTextBox" 
                                             Visibility="Collapsed" 
                                             Background="#222222" 
                                             Foreground="White" 
                                             BorderBrush="#555" 
                                             BorderThickness="1" 
                                             Padding="10,8,35,8" 
                                             HorizontalAlignment="Stretch"
                                             TextChanged="ApiTextBox_TextChanged"/>

                                    <Button x:Name="ToggleApiVisibilityButton" 
                                            Click="ToggleApiVisibility_Click" 
                                            HorizontalAlignment="Right" 
                                            Width="30" 
                                            Background="Transparent" 
                                            BorderThickness="0" 
                                            Cursor="Hand">
                                        <iconPacks:PackIconMaterial x:Name="ToggleEyeIcon" Kind="EyeOutline" Foreground="#A0A0A0" VerticalAlignment="Center"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="* Anahtarınız bilgisayarınızda yerel bir dosyada güvenle saklanır." Foreground="#666" FontSize="12" Margin="0,0,0,25" TextWrapping="Wrap"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="İptal" Style="{StaticResource GhostButton}" Padding="15,8" Margin="0,0,10,0" Click="CloseSettings_Click"/>
                            <Button Content="Kaydet ve Kapat" Foreground="Black" Background="#22C55E" FontWeight="SemiBold" BorderThickness="0" Padding="20,10" Cursor="Hand" Click="SaveSettings_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

        </Grid>
    </Border>
</Window>