                                    <ItemsControl x:Name="AttachmentsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <iconPacks:PackIconMaterial Grid.Column="0" Kind="FileOutline" Width="14" Height="14" Foreground="#60A5FA" VerticalAlignment="Center" Margin="0,0,6,0"/>
