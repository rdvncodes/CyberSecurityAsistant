                                </StackPanel>
                                <Button Grid.Column="1" Cursor="Hand" Padding="10,5" Click="BrowseAttachment_Click" Foreground="White" Background="#3B82F6" BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconMaterial Kind="Plus" Width="12" Height="12" Margin="0,0,5,0" VerticalAlignment="Center" Foreground="White"/>
