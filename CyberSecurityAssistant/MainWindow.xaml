                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="ContentSaveOutline" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Taslak Olarak Kaydet" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Content="{DynamicResource BtnSend}" Style="{StaticResource GlowScanButton}" Padding="20,10" Click="SendMail_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Şüpheli Göndericiler Overlay -->
            <Grid x:Name="SuspiciousSendersOverlay" Visibility="Collapsed" Background="#D9000000" Grid.RowSpan="4" Panel.ZIndex="100">
                <Border Background="#1A1C1E" CornerRadius="12" BorderBrush="#444" BorderThickness="1"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Width="560" MaxHeight="600" Margin="0,40">
                    <DockPanel LastChildFill="True">
                        <!-- Başlık -->
                        <Border DockPanel.Dock="Top" Background="#1A1C1E" CornerRadius="12,12,0,0" Padding="25,20,25,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <iconPacks:PackIconMaterial Kind="ShieldAccountOutline" Foreground="#EF4444" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Şüpheli Hesaplar" Foreground="White" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Bu listedeki adreslerden gelen tüm yeni mailler otomatik olarak Çöp Kutusu'na taşınır." Foreground="#888" FontSize="11" TextWrapping="Wrap"/>
