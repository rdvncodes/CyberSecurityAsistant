                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Mail Silme Onay Overlay'i — Trash veya Permanent seçimi -->
            <!-- KVKK / Disclaimer onay ekranı — ilk açılışta gösterilir, kullanıcı kabul edene kadar app etkileşimsiz.
                 Onay DB'de "kvkk_accepted_v1" anahtarıyla saklanır, sonraki açılışlarda atlanır. -->
            <Grid x:Name="KvkkOverlay" Visibility="Collapsed" Background="#E6000000" Grid.RowSpan="4" Panel.ZIndex="200">
                <Border Background="#1A1C1E" CornerRadius="12" BorderBrush="#3B82F6" BorderThickness="2"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Width="640" MaxHeight="640" Margin="0,40">
                    <DockPanel LastChildFill="True">
                        <Border DockPanel.Dock="Top" Background="#1A1C1E" CornerRadius="12,12,0,0" Padding="30,25,30,18">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <iconPacks:PackIconMaterial Kind="ShieldLockOutline" Foreground="#3B82F6" Width="26" Height="26" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Gizlilik ve Veri Kullanımı" Foreground="White" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Siber Mail &amp; Güvenlik Asistanı'na hoş geldiniz." Foreground="#A0A0A0" FontSize="13" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border DockPanel.Dock="Bottom" Background="#1A1C1E" CornerRadius="0,0,12,12" Padding="30,18,30,24" BorderBrush="#2A2D31" BorderThickness="0,1,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox x:Name="KvkkAgreeCheck" Grid.Column="0" Foreground="#D0D0D0" FontSize="12" VerticalAlignment="Center" Cursor="Hand">
                                    <CheckBox.Content>
                                        <TextBlock Text="Yukarıdaki gizlilik koşullarını okudum ve kabul ediyorum." TextWrapping="Wrap"/>
                                    </CheckBox.Content>
                                </CheckBox>
                                <Button Grid.Column="1" Content="Reddet ve Çık" Style="{StaticResource GhostButton}" Padding="14,9" Margin="0,0,10,0" Foreground="#A0A0A0" Click="KvkkDecline_Click"/>
                                <Button Grid.Column="2" x:Name="KvkkAcceptButton" Click="KvkkAccept_Click" IsEnabled="False" Padding="22,9" Foreground="White" Background="#3B82F6" BorderThickness="0" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="bd" Property="Background" Value="#33444444"/>
                                                    <Setter Property="Foreground" Value="#666"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#2563EB"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Check" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Kabul Et ve Devam Et" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <ScrollViewer Style="{StaticResource DarkScrollViewer}" Padding="30,5,20,15">
                            <StackPanel>
                                <Border Background="#0F1A2E" CornerRadius="8" Padding="14" Margin="0,0,0,12" BorderBrush="#1E3A8A" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="LockOutline" Foreground="#60A5FA" Width="18" Height="18" VerticalAlignment="Top" Margin="0,2,10,0"/>
                                        <TextBlock Foreground="#D0D0D0" FontSize="12" TextWrapping="Wrap">
                                            <Run FontWeight="SemiBold" Foreground="White">Verileriniz cihazınızdan dışarı çıkmaz.</Run>
                                            <LineBreak/>
                                            Tüm mail içerikleri, analiz sonuçları ve hesap bilgileri yerel SQLite veritabanında, bilgisayarınızda saklanır.
                                            Üçüncü taraf sunuculara aktarılmaz.
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Nasıl Çalışır?" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,8"/>
                                <StackPanel Margin="0,0,0,12">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <iconPacks:PackIconMaterial Grid.Column="0" Kind="Gmail" Width="16" Height="16" Foreground="#EA4335" VerticalAlignment="Top" Margin="0,2,8,0"/>
                                        <TextBlock Grid.Column="1" Foreground="#A0A0A0" FontSize="12" TextWrapping="Wrap">
                                            <Run FontWeight="SemiBold" Foreground="#D0D0D0">Gmail:</Run>
                                            Mailleriniz Google'ın resmi IMAP/SMTP sunucuları üzerinden çekilir. App Password'unuz Windows DPAPI ile şifrelenerek diskinizde saklanır — yalnızca aynı kullanıcı hesabınız ile çözülebilir.
                                        </TextBlock>
                                    </Grid>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <iconPacks:PackIconMaterial Grid.Column="0" Kind="Virus" Width="16" Height="16" Foreground="#22C55E" VerticalAlignment="Top" Margin="0,2,8,0"/>
                                        <TextBlock Grid.Column="1" Foreground="#A0A0A0" FontSize="12" TextWrapping="Wrap">
                                            <Run FontWeight="SemiBold" Foreground="#D0D0D0">VirusTotal:</Run>
                                            URL ve dosyalar tarandığında yalnızca SHA-256 özet (hash) veya URL adresi VirusTotal API'sine gönderilir.
                                            Mail içeriği, kişisel bilgi paylaşılmaz. Bu, antivirüs sektörünün standart kullanımıdır.
                                        </TextBlock>
                                    </Grid>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <iconPacks:PackIconMaterial Grid.Column="0" Kind="Brain" Width="16" Height="16" Foreground="#A855F7" VerticalAlignment="Top" Margin="0,2,8,0"/>
                                        <TextBlock Grid.Column="1" Foreground="#A0A0A0" FontSize="12" TextWrapping="Wrap">
                                            <Run FontWeight="SemiBold" Foreground="#D0D0D0">Yapay Zekâ (ML):</Run>
                                            Phishing ve spam tespiti bilgisayarınızda yerel olarak çalışan Flask/Python servisi (predict.exe) tarafından yapılır.
                                            Hiçbir metin veya mail içeriği harici bir API'ye gönderilmez.
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>

                                <TextBlock Text="Veri Saklama" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,6"/>
                                <TextBlock Foreground="#A0A0A0" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10">
                                    Uygulamayı kaldırdığınızda veya `siberkalkan.db` dosyasını sildiğinizde tüm veri kalıcı olarak yok olur.
                                    Hesap parolanızı istediğiniz zaman Ayarlar → "Hesabı Sıfırla" ile silebilirsiniz.
                                </TextBlock>

                                <TextBlock Text="Sorumluluk Reddi" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,6"/>
